# .env.example — copy this to .env.local for development

# ============================================================
# DATABASE (Railway PostgreSQL — get this from Railway dashboard)
# ============================================================
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# ============================================================
# AUTH SECRET (change this to a random string in production)
# ============================================================
JWT_SECRET="dict-dtc-region5-secret-change-in-production"

# ============================================================
# NEXT.JS
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"
