# ══════════════════════════════════════════════════════════════════════════════
# DICT DTC Logbook — Environment Variables
# Copy this to .env.local for local dev, or set in Railway dashboard
# Lines marked REQUIRED must be set before the app will start in production
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED
DATABASE_URL="postgresql://postgres:dTBQOLbbCgAKzdowgXvXiZBavUSYWBRf@postgres.railway.internal:5432/railway"
DATABASE_PUBLIC_URL="postgresql://postgres:dTBQOLbbCgAKzdowgXvXiZBavUSYWBRf@gondola.proxy.rlwy.net:57929/railway"
# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -base64 48
# App will throw a hard error on startup if missing in production
JWT_SECRET="replace-with-48-char-random-string-from-openssl-rand"

# ── Cron / Auto-expiry ────────────────────────────────────────────────────────
# REQUIRED if using QStash or cron-job.org
# generate with: openssl rand -hex 32
CRON_SECRET="replace-with-random-string"

# ── App URL ───────────────────────────────────────────────────────────────────
# REQUIRED — used in cron scheduling and Cloudinary callbacks
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# ── Pusher (real-time) — free tier at pusher.com ──────────────────────────────
# OPTIONAL — without these, dashboard won't update in real-time (manual refresh still works)
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# ── Cloudinary (photo CDN) — free tier at cloudinary.com ─────────────────────
# OPTIONAL — without these, photos stored as base64 in DB (less efficient)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── First-run admin setup ─────────────────────────────────────────────────────
# OPTIONAL — used to seed the first admin via PUT /api/auth
# Only needed if you don't run: npm run db:seed
SETUP_TOKEN="replace-with-random-string"

# ── Node environment ──────────────────────────────────────────────────────────
# Set automatically by Railway. Only change if self-hosting.
NODE_ENV="production"
