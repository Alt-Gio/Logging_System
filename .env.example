# ══════════════════════════════════════════════════════════════════════════════
# DICT DTC Logbook — Environment Variables
# Copy this to .env.local for local dev, or set in Railway dashboard
# Lines marked REQUIRED must be set before the app will start in production
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# ── Clerk Authentication ──────────────────────────────────────────────────────
# REQUIRED — Get from clerk.com dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ── Groq AI (Voice Assistant) ─────────────────────────────────────────────────
# REQUIRED for voice chatbot — Get from console.groq.com
# Supports multilingual: English, Tagalog, Bicolano
GROQ_API_KEY="gsk_..."

# ── Pusher (real-time) — free tier at pusher.com ──────────────────────────────
# OPTIONAL — without these, dashboard won't update in real-time (manual refresh still works)
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# ── Cloudinary (photo CDN) — free tier at cloudinary.com ─────────────────────
# OPTIONAL — without these, photos stored as base64 in DB (less efficient)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Node environment ──────────────────────────────────────────────────────────
# Set automatically by Railway. Only change if self-hosting.
NODE_ENV="production"
