generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_PUBLIC_URL")
}

model LogEntry {
  id                   String    @id @default(cuid())
  fullName             String
  agency               String
  purpose              String
  equipmentUsed        String[]
  date                 DateTime  @default(now())
  timeIn               DateTime  @default(now())
  timeOut              DateTime?
  signature            String?
  photoDataUrl         String?   @db.Text
  plannedDurationHours Float     @default(1)
  archived             Boolean   @default(false)
  pcId                 String?
  pc                   PC?       @relation(fields: [pcId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([timeIn])
  @@index([pcId])
  @@index([archived])
  @@map("log_entries")
}

model PC {
  id         String    @id @default(cuid())
  name       String
  ipAddress  String    @unique
  macAddress String?
  location   String?
  isActive   Boolean   @default(true)
  lastSeen   DateTime?
  status     PCStatus  @default(OFFLINE)
  ssid       String?
  specs      String?
  icon       String?   @default("🖥️")
  gridCol    Int?      @default(1)
  gridRow    Int?      @default(1)
  logs       LogEntry[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("pcs")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  @@map("admins")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum PCStatus {
  ONLINE
  OFFLINE
  IN_USE
  MAINTENANCE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}
